# Supabase
# In sviluppo locale: valori prodotti da `supabase status`.
# In produzione: valori del progetto Supabase Cloud.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenAI
# Se vuoto, l'app usa un classificatore di fallback rule-based deterministico
# (utile per sviluppo/demo senza chiave). In produzione impostare la chiave reale.
OPENAI_API_KEY=sk-...

# URL pubblico dell'app (usato per i link nei riepiloghi)
NEXT_PUBLIC_APP_URL=http://localhost:3000
